  <proof id="0">
    <assumption linenum="0">
      <raw>((A Ôćö ┬ČB) Ôłž (B Ôćö (B ÔłĘ A)))</raw>
    </assumption>
    <step linenum="1">
      <raw>(((A Ôłž ┬ČB) ÔłĘ (┬ČA Ôłž ┬Č┬ČB)) Ôłž (B Ôćö (B ÔłĘ A)))</raw>
      <rule>BICONDITIONAL_EQUIVALENCE</rule>
      <premise>0</premise>
    </step>
    <step linenum="2">
      <raw>(((A Ôłž ┬ČB) ÔłĘ (┬ČA Ôłž ┬Č┬ČB)) Ôłž ((B Ôłž (B ÔłĘ A)) ÔłĘ (┬ČB Ôłž ┬Č((B ÔłĘ A)))))</raw>
      <rule>BICONDITIONAL_EQUIVALENCE</rule>
      <premise>1</premise>
    </step>
    <step linenum="3">
      <raw>(((A Ôłž ┬ČB) ÔłĘ (┬ČA Ôłž B)) Ôłž ((B Ôłž (B ÔłĘ A)) ÔłĘ (┬ČB Ôłž ┬Č((B ÔłĘ A)))))</raw>
      <rule>DOUBLENEGATION_EQUIV</rule>
      <premise>2</premise>
    </step>
    <step linenum="4">
      <raw>(((A Ôłž ┬ČB) ÔłĘ (┬ČA Ôłž B)) Ôłž (B ÔłĘ (┬ČB Ôłž ┬Č((B ÔłĘ A)))))</raw>
      <rule>ABSORPTION</rule>
      <premise>3</premise>
    </step>
    <step linenum="5">
      <raw>(((A Ôłž ┬ČB) ÔłĘ (┬ČA Ôłž B)) Ôłž (B ÔłĘ (┬ČB Ôłž (┬ČB Ôłž ┬ČA))))</raw>
      <rule>DE_MORGAN</rule>
      <premise>4</premise>
    </step>
    <step linenum="6">
      <raw>(((A Ôłž ┬ČB) ÔłĘ (┬ČA Ôłž B)) Ôłž (B ÔłĘ (┬ČB Ôłž ┬ČA)))</raw>
      <rule>ABSORPTION</rule>
      <premise>5</premise>
    </step>
    <step linenum="7">
      <raw>(((A ÔłĘ (┬ČA Ôłž B)) Ôłž (┬ČB ÔłĘ (┬ČA Ôłž B))) Ôłž (B ÔłĘ (┬ČB Ôłž ┬ČA)))</raw>
      <rule>DISTRIBUTION</rule>
      <premise>6</premise>
    </step>
    <step linenum="8">
      <raw>((((A ÔłĘ ┬ČA) Ôłž (A ÔłĘ B)) Ôłž (┬ČB ÔłĘ (┬ČA Ôłž B))) Ôłž (B ÔłĘ (┬ČB Ôłž ┬ČA)))</raw>
      <rule>DISTRIBUTION</rule>
      <premise>7</premise>
    </step>
    <step linenum="9">
      <raw>((((A ÔłĘ ┬ČA) Ôłž (A ÔłĘ B)) Ôłž ((┬ČB ÔłĘ ┬ČA) Ôłž (┬ČB ÔłĘ B))) Ôłž (B ÔłĘ (┬ČB Ôłž ┬ČA)))</raw>
      <rule>DISTRIBUTION</rule>
      <premise>8</premise>
    </step>
    <step linenum="10">
      <raw>((((A ÔłĘ ┬ČA) Ôłž (A ÔłĘ B)) Ôłž ((┬ČB ÔłĘ ┬ČA) Ôłž (┬ČB ÔłĘ B))) Ôłž ((B ÔłĘ ┬ČB) Ôłž (B ÔłĘ ┬ČA)))</raw>
      <rule>DISTRIBUTION</rule>
      <premise>9</premise>
    </step>
    <step linenum="11">
      <raw>(((ÔŐĄ Ôłž (A ÔłĘ B)) Ôłž ((┬ČB ÔłĘ ┬ČA) Ôłž (┬ČB ÔłĘ B))) Ôłž ((B ÔłĘ ┬ČB) Ôłž (B ÔłĘ ┬ČA)))</raw>
      <rule>COMPLEMENT</rule>
      <premise>10</premise>
    </step>
    <step linenum="12">
      <raw>(((ÔŐĄ Ôłž (A ÔłĘ B)) Ôłž ((┬ČB ÔłĘ ┬ČA) Ôłž ÔŐĄ)) Ôłž ((B ÔłĘ ┬ČB) Ôłž (B ÔłĘ ┬ČA)))</raw>
      <rule>COMPLEMENT</rule>
      <premise>11</premise>
