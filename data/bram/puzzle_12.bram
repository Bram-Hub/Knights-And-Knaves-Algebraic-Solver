    <step linenum="13">
      <raw>(((ÔŐĄ Ôłž (A ÔłĘ B)) Ôłž ((┬ČB ÔłĘ ┬ČA) Ôłž ÔŐĄ)) Ôłž (ÔŐĄ Ôłž (B ÔłĘ ┬ČA)))</raw>
      <rule>COMPLEMENT</rule>
      <premise>12</premise>
    </step>
    <step linenum="14">
      <raw>(((A ÔłĘ B) Ôłž ((┬ČB ÔłĘ ┬ČA) Ôłž ÔŐĄ)) Ôłž (ÔŐĄ Ôłž (B ÔłĘ ┬ČA)))</raw>
      <rule>IDENTITY</rule>
      <premise>13</premise>
    </step>
    <step linenum="15">
      <raw>(((A ÔłĘ B) Ôłž (┬ČB ÔłĘ ┬ČA)) Ôłž (ÔŐĄ Ôłž (B ÔłĘ ┬ČA)))</raw>
      <rule>IDENTITY</rule>
      <premise>14</premise>
    </step>
    <step linenum="16">
