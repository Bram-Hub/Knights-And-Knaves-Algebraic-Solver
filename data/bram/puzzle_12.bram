      <rule>ASSOCIATION</rule>
      <premise>19</premise>
    </step>
    <step linenum="21">
      <raw>((B ÔłĘ (A Ôłž ┬ČA)) Ôłž (┬ČB ÔłĘ ┬ČA))</raw>
      <rule>DISTRIBUTION</rule>
      <premise>20</premise>
    </step>
    <step linenum="22">
      <raw>((B ÔłĘ ÔŐą) Ôłž (┬ČB ÔłĘ ┬ČA))</raw>
      <rule>COMPLEMENT</rule>
      <premise>21</premise>
    </step>
    <step linenum="23">
      <raw>(B Ôłž (┬ČB ÔłĘ ┬ČA))</raw>
      <rule>IDENTITY</rule>
      <premise>22</premise>
    </step>
    <step linenum="24">
      <raw>((B Ôłž ┬ČB) ÔłĘ (B Ôłž ┬ČA))</raw>
      <rule>DISTRIBUTION</rule>
      <premise>23</premise>
    </step>
    <step linenum="25">
      <raw>(ÔŐą ÔłĘ (B Ôłž ┬ČA))</raw>
      <rule>COMPLEMENT</rule>
      <premise>24</premise>
    </step>
    <step linenum="26">
      <raw>(B Ôłž ┬ČA)</raw>
      <rule>IDENTITY</rule>
      <premise>25</premise>
